# Supabase — copy to .env.local and fill in. Never commit real secrets.
# Public values are safe to expose to the browser (prefixed with NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used by trusted server code (migrations/admin tasks).
# NEVER import this in client components or prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
