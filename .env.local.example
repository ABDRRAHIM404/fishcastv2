# Supabase — copy to .env.local and fill in. Never commit real secrets.
# Public values are safe to expose to the browser (prefixed with NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used by trusted server code (migrations/admin tasks).
# NEVER import this in client components or prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mapbox — public access token used by the interactive map (browser-safe).
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-access-token

# Gemini (Phase 9) — server-only. Powers the interpretive AI recommendation on
# the spot details page. NEVER prefix with NEXT_PUBLIC_ or import client-side.
# When unset (or AI_ENABLED=false), the app serves a deterministic fallback.
GEMINI_API_KEY=your-gemini-api-key
# Optional kill switch: set to "false" to disable Gemini calls entirely.
AI_ENABLED=true
